{
  "name": "requests",
  "type": "client",
  "language": "python",
  "protocolFamilies": [
    "evm",
    "svm",
    "tvm"
  ],
  "x402Versions": [
    1,
    2
  ],
  "schemes": [
    "exact",
    "upto",
    "batch-settlement"
  ],
  "evm": {
    "assetTransferMethods": [
      "eip3009",
      "permit2"
    ]
  },
  "extensions": [
    "eip2612GasSponsoring",
    "erc20ApprovalGasSponsoring"
  ],
  "description": "Python requests client with x402 v2 HTTP adapter",
  "environment": {
    "required": [
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "EVM_PRIVATE_KEY",
      "SVM_PRIVATE_KEY",
      "TVM_PRIVATE_KEY",
      "EVM_RPC_URL",
      "TVM_NETWORK",
      "TVM_PROVIDER",
      "TONCENTER_API_KEY",
      "TONCENTER_BASE_URL",
      "TONAPI_API_KEY",
      "TONAPI_BASE_URL",
      "CHANNEL_SALT",
      "EVM_VOUCHER_SIGNER_PRIVATE_KEY",
      "BATCH_SETTLEMENT_PHASE"
    ]
  }
}
