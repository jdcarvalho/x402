{
  "name": "httpx",
  "type": "client",
  "language": "python",
  "protocolFamilies": [
    "evm",
    "svm"
  ],
  "x402Versions": [
    1,
    2
  ],
  "schemes": ["exact", "upto"],
  "evm": {
    "transferMethods": ["eip3009", "permit2", "upto"]
  },
  "extensions": [
    "eip2612GasSponsoring",
    "erc20ApprovalGasSponsoring"
  ],
  "description": "Python httpx client with x402 v2 payment hooks",
  "environment": {
    "required": [
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "EVM_PRIVATE_KEY",
      "SVM_PRIVATE_KEY",
      "EVM_RPC_URL"
    ]
  }
}
